# Sanity (Legacy - can be removed if not using Sanity)
NEXT_PUBLIC_SANITY_PROJECT_ID=placeholder
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
SANITY_API_TOKEN=

# Supabase (Primary Database)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET= # Linux: `openssl rand -hex 32` or go to https://generate-secret.vercel.app/32

# Encryption (for password reset tokens and sensitive data)
TOKEN_ENCRYPTION_KEY=your-encryption-key-here-change-in-production
TOKEN_ENCRYPTION_SALT=your-salt-here-change-in-production

# Mobile (Capacitor)
NEXT_PUBLIC_APP_URL=https://your-production-url.com

# Android Release Signing (for APK builds)
EDUVERSE_RELEASE_STORE_FILE=/path/to/eduverse-release.jks
EDUVERSE_RELEASE_STORE_PASSWORD=your-store-password
EDUVERSE_RELEASE_KEY_ALIAS=eduverse
EDUVERSE_RELEASE_KEY_PASSWORD=your-key-password

# iOS Signing (for IPA builds)
EDUVERSE_IOS_TEAM_ID=XXXXXXXXXX
EDUVERSE_IOS_CERTIFICATE_NAME="iPhone Distribution: Your Company Name"
EDUVERSE_IOS_PROVISIONING_PROFILE_NAME=Eduverse_AdHoc

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OpenAI (for Whisper transcription)
OPENAI_API_KEY=sk-...

# Processing limits
MAX_VIDEO_SIZE_MB=500
MAX_DOCUMENT_SIZE_MB=50
MAX_VIDEO_DURATION_HOURS=2

# Mock Data (Development)
NEXT_PUBLIC_USE_MOCK_DATA=true

SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here
