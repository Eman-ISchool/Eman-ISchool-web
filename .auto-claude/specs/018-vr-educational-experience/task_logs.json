          "detail": "     1→'use client';\n     2→\n     3→import { useState, useCallback, useMemo } from 'react';\n     4→import dynamic from 'next/dynamic';\n     5→import Link from 'next/link';\n     6→import { Button } from '@/components/ui/button';\n     7→import { Badge } from '@/components/ui/badge';\n     8→import { Card, CardContent } from '@/components/ui/card';\n     9→import {\n    10→  ArrowLeft,\n    11→  X,\n    12→  Volume2,\n    13→  VolumeX,\n    14→  Info,\n    15→  BookOpen,\n    16→  Award,\n    17→  Clock,\n    18→  MapPin,\n    19→  Pyramid,\n    20→  Maximize2,\n    21→  Minimize2,\n    22→} from 'lucide-react';\n    23→import type {\n    24→  VRExperience,\n    25→  VRScene,\n    26→  InfoHotspot,\n    27→  NavigationHotspot,\n    28→  QuizHotspot,\n    29→  VRLanguage,\n    30→  AnyHotspot,\n    31→} from '@/types/vr';\n    32→import { VRHotspots } from '@/components/vr/hotspots/VRHotspots';\n    33→import { VRScene as VRSceneComponent } from '@/components/vr/scenes/VRScene';\n    34→import { VRNavigation } from '@/components/vr/ui/VRNavigation';\n    35→\n    36→// Dynamically import VR components to avoid SSR issues\n    37→const VRCanvas = dynamic(\n    38→  () => import('@/components/vr/canvas/VRCanvas').then((mod) => mod.VRCanvas),\n    39→  { ssr: false }\n    40→);\n    41→\n    42→const VRInfoPanel = dynamic(\n    43→  () => import('@/components/vr/ui/VRInfoPanel').then((mod) => mod.VRInfoPanel),\n    44→  { ssr: false }\n    45→);\n    46→\n    47→/**\n    48→ * Pyramids of Giza VR Experience Page\n    49→ *\n    50→ * Immersive VR field trip to the Pyramids of Giza with multiple scenes,\n    51→ * educational hotspots, and interactive quizzes.\n    52→ */\n    53→export default function PyramidsOfGizaPage() {\n    54→  const [language, setLanguage] = useState<VRLanguage>('ar');\n    55→  const [currentSceneId, setCurrentSceneId] = useState('great-pyramid-exterior');\n    56→  const [activeInfoHotspot, setActiveInfoHotspot] = useState<InfoHotspot | null>(null);\n    57→  const [activeQuizHotspot, setActiveQuizHotspot] = useState<QuizHotspot | null>(null);\n    58→  const [answeredQuizIds, setAnsweredQuizIds] = useState<string[]>([]);\n    59→  const [quizAnswers, setQuizAnswers] = useState<Record<string, string>>({});\n    60→  const [isMuted, setIsMuted] = useState(false);\n    61→  const [showNavigation, setShowNavigation] = useState(false);\n    62→  const [isFullscreen, setIsFullscreen] = useState(false);\n    63→  const [visitedScenes, setVisitedScenes] = useState<string[]>(['great-pyramid-exterior']);\n    64→\n    65→  // Define the VR experience data\n    66→  const vrExperience: VRExperience = useMemo(() => ({\n    67→    id: 'pyramids-of-giza',\n    68→    slug: 'pyramids-of-giza',\n    69→    title: {\n    70→      en: 'Pyramids of Giza',\n    71→      ar: 'أهرامات الجيزة',\n    72→    },\n    73→    description: {\n    74→      en: 'Experience the grandeur of the Great Pyramid, explore the Sphinx, and learn about ancient Egyptian civilization through immersive 360° views.',\n    75→      ar: 'اختبر عظمة الهرم الأكبر، واستكشف أبو الهول، وتعلم عن الحضارة المصرية القديمة من خلال مشاهد 360° غامرة.',\n    76→    },\n    77→    category: 'field-trip',\n    78→    subject: 'Egyptian History',\n    79→    gradeLevel: ['5-6', '7-9', '10-12'],\n    80→    difficulty: 'intermediate',\n    81→    thumbnailUrl: 'https://placehold.co/800x600/f59e0b/ffffff?text=Pyramids+of+Giza',\n    82→    coverImageUrl: 'https://placehold.co/1200x600/f59e0b/ffffff?text=Pyramids+of+Giza',\n    83→    estimatedDuration: 30,\n    84→    scenes: [],\n    85→    initialSceneId: 'great-pyramid-exterior',\n    86→    learningObjectives: [\n    87→      {\n    88→        en: 'Understand the construction techniques of the Great Pyramid',\n    89→        ar: 'فهم تقنيات بناء الهرم الأكبر',\n    90→      },\n    91→      {\n    92→        en: 'Learn about the pharaohs and their significance',\n    93→        ar: 'التعرف على الفراعنة وأهميتهم',\n    94→      },\n    95→      {\n    96→        en: 'Explore the cultural and religious beliefs of ancient Egypt',\n    97→        ar: 'استكشاف المعتقدات الثقافية والدينية لمصر القديمة',\n    98→      },\n    99→    ],\n   100→    keywords: ['pyramids', 'giza', 'egypt', 'pharaoh', 'sphinx', 'ancient'],\n   101→    isPublished: true,\n   102→    publishedAt: '2026-01-12T00:00:00Z',\n   103→    createdAt: '2026-01-12T00:00:00Z',\n   104→    updatedAt: '2026-01-12T00:00:00Z',\n   105→  }), []);\n   106→\n   107→  // Define scenes with hotspots\n   108→  const scenes: VRScene[] = useMemo(() => [\n   109→    {\n   110→      id: 'great-pyramid-exterior',\n   111→      title: {\n   112→        en: 'Great Pyramid - Exterior View',\n   113→        ar: 'الهرم الأكبر - المنظر الخارجي',\n   114→      },\n   115→      description: {\n   116→        en: 'Stand before the Great Pyramid of Khufu, the largest of the three pyramids',\n   117→        ar: 'قف أمام هرم خوفو الأكبر، أكبر الأهرامات الثلاثة',\n   118→      },\n   119→      environmentType: '360-image',\n   120→      imageUrl: 'https://placehold.co/4096x2048/d4a574/ffffff?text=Great+Pyramid+Exterior',\n   121→      thumbnailUrl: 'https://placehold.co/400x300/d4a574/ffffff?text=Great+Pyramid',\n   122→      hotspots: [\n   123→        {\n   124→          id: 'info-pyramid-construction',\n   125→          type: 'info',\n   126→          position: { x: -10, y: 5, z: -20 },\n   127→          title: {\n   128→            en: 'Construction Techniques',\n   129→            ar: 'تقنيات البناء',\n   130→          },\n   131→          description: {\n   132→            en: 'Learn how ancient Egyptians built this wonder',\n   133→            ar: 'تعرف على كيفية بناء المصريين القدماء لهذه الأعجوبة',\n   134→          },\n   135→          content: {\n   136→            title: {\n   137→              en: 'How Were the Pyramids Built?',\n   138→              ar: 'كيف تم بناء الأهرامات؟',\n   139→            },\n   140→            description: {\n   141→              en: 'The Great Pyramid was built using approximately 2.3 million stone blocks, each weighing between 2.5 to 15 tons. Ancient Egyptians used copper tools, wooden sledges, and ramps to move and position these massive stones. The precision of construction is remarkable - the base is level to within 2.1 cm, and the sides are aligned to the cardinal directions with incredible accuracy. It took an estimated 20 years and 100,000 workers to complete.',\n   142→              ar: 'تم بناء الهرم الأكبر باستخدام حوالي 2.3 مليون كتلة حجرية، يتراوح وزن كل منها بين 2.5 إلى 15 طناً. استخدم المصريون القدماء أدوات نحاسية، وزلاجات خشبية، ومنحدرات لنقل وتحريك هذه الأحجار الضخمة. دقة البناء ملحوظة - القاعدة مستوية في حدود 2.1 سم، والجوانب محاذية للاتجاهات الأصلية بدقة مذهلة. استغرق البناء حوالي 20 عاماً و100,000 عامل.',\n   143→            },\n   144→            imageUrl: 'https://placehold.co/600x400/8b7355/ffffff?text=Construction',\n   145→          },\n   146→          color: '#3b82f6',\n   147→        } as InfoHotspot,\n   148→        {\n   149→          id: 'info-khufu',\n   150→          type: 'info',\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n",
