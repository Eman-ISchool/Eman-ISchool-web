// ─────────────────────────────────────────────────────────────
// Online Coffee Gathering — Prisma Schema
// Database: PostgreSQL 15
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────

enum RoomType {
  PUBLIC
  PRIVATE
}

enum RoomStatus {
  WAITING
  ACTIVE
  CLOSING
  CLOSED
}

enum DrinkType {
  COFFEE
  TEA
  OTHER
}

enum ParticipantRole {
  HOST
  GUEST
}

enum ViolationType {
  PROFANITY
  HATE_SPEECH
  SPAM
  OFF_TOPIC
  HARASSMENT
}

enum ModerationSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ── Models ───────────────────────────────────────────────────

model GuestSession {
  id        String   @id @default(uuid()) @db.Uuid
  nickname  String
  avatarColor String
  token     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime

  participants RoomParticipant[]

  @@index([token])
  @@index([expiresAt])
}

model Room {
  id              String     @id @default(uuid()) @db.Uuid
  type            RoomType
  status          RoomStatus @default(WAITING)
  drinkType       DrinkType
  topic           String
  inviteCode      String?    @unique
  maxParticipants Int
  createdAt       DateTime   @default(now())
  closedAt        DateTime?

  participants     RoomParticipant[]
  turnRecords      TurnRecord[]
  moderationEvents ModerationEvent[]

  @@index([status])
  @@index([drinkType, topic, status])
  @@index([inviteCode])
}

model RoomParticipant {
  id          String          @id @default(uuid()) @db.Uuid
  sessionId   String          @db.Uuid
  roomId      String          @db.Uuid
  nickname    String
  avatarColor String
  role        ParticipantRole
  isMuted     Boolean         @default(false)
  joinedAt    DateTime        @default(now())
  leftAt      DateTime?

  session          GuestSession      @relation(fields: [sessionId], references: [id])
  room             Room              @relation(fields: [roomId], references: [id])
  turnRecords      TurnRecord[]
  moderationEvents ModerationEvent[]

  @@unique([sessionId, roomId])
  @@index([sessionId])
  @@index([roomId])
}

model TurnRecord {
  id              String   @id @default(uuid()) @db.Uuid
  roomId          String   @db.Uuid
  participantId   String   @db.Uuid
  startedAt       DateTime @default(now())
  endedAt         DateTime?
  durationSeconds Int?

  room        Room            @relation(fields: [roomId], references: [id])
  participant RoomParticipant @relation(fields: [participantId], references: [id])
}

model ModerationEvent {
  id            String             @id @default(uuid()) @db.Uuid
  roomId        String             @db.Uuid
  participantId String             @db.Uuid
  violationType ViolationType
  severity      ModerationSeverity
  content       String
  aiConfidence  Float
  actionTaken   String
  createdAt     DateTime           @default(now())

  room        Room            @relation(fields: [roomId], references: [id])
  participant RoomParticipant @relation(fields: [participantId], references: [id])

  @@index([roomId])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  roomId    String?
  sessionId String?
  action    String
  details   Json?
  createdAt DateTime @default(now())
}
