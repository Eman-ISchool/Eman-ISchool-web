# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL via Prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/coffee_gathering?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your-secret-key-change-in-production

# OpenAI (for STT and AI features)
OPENAI_API_KEY=your-openai-api-key

# CORS
CORS_ORIGIN=http://localhost:3000

# TURN Server (optional, for NAT traversal)
# TURN_URLS=turn:your-turn-server.com:3478,turns:your-turn-server.com:5349
# TURN_USERNAME=your-turn-username
# TURN_CREDENTIAL=your-turn-credential

# SFU / mediasoup (auto-enabled for rooms > 4 participants)
SFU_ENABLED=true
# SFU_LISTEN_IP=0.0.0.0
# SFU_ANNOUNCED_IP=your-public-ip
# SFU_MIN_PORT=40000
# SFU_MAX_PORT=49999

# Cleanup cron
CLEANUP_INTERVAL_MINUTES=15
CLEANUP_SESSION_TTL_HOURS=24
CLEANUP_ROOM_IDLE_MINUTES=60
